generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id           String   @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  facilitySize String
  region       String
  notes        String?
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("UNREAD") // UNREAD, READ, ARCHIVED
  createdAt DateTime @default(now())
}

model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String
  content         String   @db.Text
  coverImage      String?
  published       Boolean  @default(false)
  authorName      String   @default("Peter")
  customCreatedAt DateTime? // For back-dating historical posts
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Investor {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  organization String
  accessLevel  String   @default("PUBLIC")
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
}
